# Tag de Amazon Associates. Sin él, los botones de compra siguen funcionando
# pero sin atribución de afiliado.
NEXT_PUBLIC_AMAZON_TAG=tuassociatetag-21

# URL pública del sitio (usada en metadata, OG y sitemap).
NEXT_PUBLIC_SITE_URL=https://www.padeltotal.example

# ID de medición de Google Analytics 4 (ej. G-XXXXXXXXXX). Opcional.
NEXT_PUBLIC_GA_ID=

# Keepa API (precios/histórico Amazon) — https://keepa.com/#!api
KEEPA_API_KEY=

# Supabase (sistema nuevo de claves: publishable/secret, no legacy anon/service_role)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secreto compartido con el cron de Vercel (Authorization: Bearer <valor>)
CRON_SECRET=
